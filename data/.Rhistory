library(tidyverse)
library(caret)
# ---------------------------------------------------------
# Project: Advanced Real Estate Valuation Analysis
# Comparison: KNN (Comps) vs. Random Forest
# ---------------------------------------------------------
rm(list = ls())
#library
library(tidyverse)
library(caret)
library(FNN) #KNN
library(randomForest) #randomforest
library(scales)
#reproducible
set.seed(123)
#set working directory
setwd("D:/CSC542 Dataset")
train_raw <- read.csv("train.csv", stringsAsFactors = FALSE)
# data cleaning: filter out houses larger than 4000 sq ft
# These are "mega-mansions" that follow different market rules.
# Including them would "confuse" the model and make it less accurate for the average home.
train_data <- train_raw %>% filter(GrLivArea < 4000)
#We convert text (Excellent, Good) into numbers (5, 4) so the computer can calculate "Quality."
#"None": None
#"Po": Poot
#“FA”: Fair
#"TA": Target
#"Gd": Good
#"Ex": Excellent
qual_map <- c("None" = 0, "Po" = 1, "Fa" = 2, "TA" = 3, "Gd" = 4, "Ex" = 5)
processed_data <- train_data %>%
# Instead of deleting rows, we treat the absence of a feature (like a Pool) as a value.
mutate(across(c("Alley", "MasVnrType", "BsmtQual", "BsmtCond", "BsmtExposure",
"BsmtFinType1", "BsmtFinType2", "FireplaceQu", "GarageType",
"GarageFinish", "GarageQual", "GarageCond", "PoolQC", "Fence", "MiscFeature"),
~replace_na(., "None"))) %>%
# NUMERIC IMPUTATION & FEATURE CREATION
mutate(
# Fill missing numeric values with medians or logical defaults
LotFrontage = if_else(is.na(LotFrontage), median(LotFrontage, na.rm = TRUE), LotFrontage),
MasVnrArea = if_else(is.na(MasVnrArea), 0, MasVnrArea),
GarageYrBlt = if_else(is.na(GarageYrBlt), as.numeric(YearBuilt), as.numeric(GarageYrBlt)),
Electrical = if_else(is.na(Electrical), "SBrkr", Electrical),
# ORDINAL ENCODING: Convert quality text to numbers based on the map above
ExterQualNum = as.numeric(recode(ExterQual, !!!qual_map)),
KitchenQualNum = as.numeric(recode(KitchenQual, !!!qual_map)),
# We combine FullBath and HalfBath into one TotalBath because that’s how buyers think.
TotalBath = FullBath + (0.5 * HalfBath) + BsmtFullBath + (0.5 * BsmtHalfBath),
# AGGREGATION: Combine living area and basement into Total Square Footage
TotalSF = GrLivArea + TotalBsmtSF,
# DERIVED FEATURE: Calculate age at time of sale
HouseAge = YrSold - YearBuilt,
# TARGET TRANSFORMATION: Log-transform SalePrice to normalize skewed data and stabilize variance
LogSalePrice = log(SalePrice)
)
# 4. Data Partitioning (80% Train / 20% Test)
# We train the model on 80% and keep 20% "hidden" to test how it performs on new listings.
train_idx <- createDataPartition(processed_data$LogSalePrice, p = 0.8, list = FALSE)
data_train <- processed_data[train_idx, ]
data_test  <- processed_data[-train_idx, ]
# 5. Target Encoding (Neighborhood Valuation Index)
# Calculate mean price per neighborhood using ONLY training data to prevent DATA LEAKAGE.
# This mathematically represents "Location, Location, Location."
nb_map <- data_train %>%
group_by(Neighborhood) %>%
summarise(NB_MeanLogPrice = mean(LogSalePrice))
data_train <- data_train %>% left_join(nb_map, by = "Neighborhood")
data_test  <- data_test %>% left_join(nb_map, by = "Neighborhood")
# 6. Feature Selection & Standardization
# We select 8 core predictors based on real estate logic and statistical significance.
features <- c("TotalSF", "OverallQual", "TotalBath", "HouseAge",
"LotArea", "NB_MeanLogPrice", "GarageCars", "KitchenQualNum")
# Z-SCORE SCALING: Scale features to have mean 0 and standard deviation 1.
# Essential for KNN so that large numbers (like LotArea) don't overpower small ones (like Bathrooms).
scaler <- preProcess(data_train[, features], method = c("center", "scale"))
x_train_scaled <- predict(scaler, data_train[, features])
x_test_scaled  <- predict(scaler, data_test[, features])
y_train <- data_train$LogSalePrice
y_test  <- data_test$LogSalePrice
# KNN HYPERPARAMETER TUNING: Use 10-fold Cross-Validation to find the best "k" (number of neighbors)
# This mimics the "Comparable Sales" approach by finding the most similar historical properties.
knn_control <- trainControl(method = "cv", number = 10)
knn_grid <- expand.grid(k = seq(1, 20, by = 2)) # Test odd numbers 1 to 19
knn_tuned <- train(x = x_train_scaled, y = y_train, method = "knn",
trControl = knn_control, tuneGrid = knn_grid)
knn_pred_log <- predict(knn_tuned, newdata = x_test_scaled)
# RANDOM FOREST TRAINING: Grow 500 decision trees to capture complex, non-linear interactions.
# This "Jury of Experts" approach is usually more robust than single-logic models.
rf_model <- randomForest(x = x_train_scaled, y = y_train,
ntree = 500, importance = TRUE)
rf_pred_log <- predict(rf_model, newdata = x_test_scaled)
# 8. Results Post-Processing & Tiering
results <- data.frame(
Actual_USD = exp(y_test),
KNN_USD    = exp(knn_pred_log),
RF_USD     = exp(rf_pred_log)
) %>%
mutate(
KNN_Error_USD = abs(Actual_USD - KNN_USD),
RF_Error_USD  = abs(Actual_USD - RF_USD),
KNN_APE = KNN_Error_USD / Actual_USD,
RF_APE  = RF_Error_USD / Actual_USD
)
# MARKET SEGMENTATION: Divide the test set into 3 equal-sized tiers (Low, Mid, Luxury)
# This allows us to see where the models succeed and where they struggle.
results$Price_Tier <- cut(results$Actual_USD,
breaks = quantile(results$Actual_USD, probs = c(0, 0.33, 0.66, 1)),
labels = c("Low-End", "Mid-Range", "Luxury"), include.lowest = TRUE)
# Chart 1: 10-fold Cross-Validation
knn_tuned
# Chart 2: Residual Analysis - Identifies if the model consistently overprices or underprices homes.
ggplot(results, aes(x = Actual_USD, y = (RF_USD - Actual_USD))) +
geom_segment(aes(xend = Actual_USD, y = 0, yend = (RF_USD - Actual_USD)), color = "gray", alpha = 0.5) +
geom_point(color = "#00BFC4", alpha = 0.6) +
geom_hline(yintercept = 0, linetype = "dashed") +
scale_x_continuous(labels = dollar) + scale_y_continuous(labels = dollar) +
labs(title = "Chart 2: Random Forest Residual Analysis", subtitle = "Prediction Bias") +
theme_minimal()
# Chart 2: Fit Tightness - Shows how close predicted dots are to the "perfect prediction" 45-degree line.
ggplot(results, aes(x = Actual_USD)) +
geom_point(aes(y = KNN_USD, color = "KNN (Comps)"), alpha = 0.3) +
geom_point(aes(y = RF_USD, color = "Random Forest"), alpha = 0.3) +
geom_abline(intercept = 0, slope = 1, linetype = "dashed") +
scale_x_continuous(labels = dollar) + scale_y_continuous(labels = dollar) +
labs(
title = "Chart 2: Predicted vs. Actual Sale Price",
x = "Actual Sale Price (USD)",        # 明确 X 轴
y = "Predicted Sale Price (USD)",     # 修改这里：将 KNN_USD 改为通用标题
color = "Model"
) +
theme_minimal()
# Chart 3: Feature Importance - Explains which house attributes drive value the most in the AI model.
importance_data <- as.data.frame(importance(rf_model))
importance_data <- as.data.frame(importance(rf_model))
importance_data$Feature <- rownames(importance_data)
ggplot(importance_data, aes(x = reorder(Feature, `%IncMSE`), y = `%IncMSE`)) +
geom_bar(stat = "identity", fill = "steelblue") +
coord_flip() +
labs(title = "Chart 3: Feature Importance (Key Price Drivers)", x = "Features", y = "Importance (% Inc MSE)") +
theme_minimal()
# Chart 3: Error Consistency - Visualizes which model is more stable across different price points.
ggplot(results, aes(x = Actual_USD)) +
geom_point(aes(y = KNN_Error_USD, color = "KNN (Comps)"), alpha = 0.4) +
geom_point(aes(y = RF_Error_USD, color = "Random Forest"), alpha = 0.4) +
geom_smooth(aes(y = KNN_Error_USD, color = "KNN (Comps)"), se = FALSE) +
geom_smooth(aes(y = RF_Error_USD, color = "Random Forest"), se = FALSE) +
scale_x_continuous(labels = dollar) + scale_y_continuous(labels = dollar) +
labs(
title = "Chart 3: Error Consistency Across Price Ranges",
x = "Actual Sale Price (USD)",        # 统一 X 轴格式
y = "Absolute Error (USD)",           # 修改这里：将 KNN_Error_USD 改为通用标题
color = "Model"
) +
theme_minimal()
# Chart 2: Residual Analysis - Identifies if the model consistently overprices or underprices homes.
ggplot(results, aes(x = Actual_USD, y = (RF_USD - Actual_USD))) +
geom_segment(aes(xend = Actual_USD, y = 0, yend = (RF_USD - Actual_USD)), color = "gray", alpha = 0.5) +
geom_point(color = "#00BFC4", alpha = 0.6) +
geom_hline(yintercept = 0, linetype = "dashed") +
scale_x_continuous(labels = dollar) + scale_y_continuous(labels = dollar) +
labs(title = "Chart 2: Random Forest Residual Analysis", subtitle = "Prediction Bias") +
theme_minimal()
