geom_point(color = "#00BFC4", alpha = 0.6) +
geom_hline(yintercept = 0, linetype = "dashed") +
scale_x_continuous(labels = dollar) + scale_y_continuous(labels = dollar) +
labs(title = "Chart 7: Random Forest Residual Analysis", subtitle = "Prediction Bias") +
theme_minimal()
# Chart 3: Feature Importance - Explains which house attributes drive value the most in the AI model.
importance_data <- as.data.frame(importance(rf_model))
importance_data <- as.data.frame(importance(rf_model))
importance_data$Feature <- rownames(importance_data)
ggplot(importance_data, aes(x = reorder(Feature, `%IncMSE`), y = `%IncMSE`)) +
geom_bar(stat = "identity", fill = "steelblue") +
coord_flip() +
labs(title = "Chart 6: Feature Importance (Key Price Drivers)", x = "Features", y = "Importance (% Inc MSE)") +
theme_minimal()
# Chart 2: Fit Tightness - Shows how close predicted dots are to the "perfect prediction" 45-degree line.
ggplot(results, aes(x = Actual_USD)) +
geom_point(aes(y = KNN_USD, color = "KNN (Comps)"), alpha = 0.3) +
geom_point(aes(y = RF_USD, color = "Random Forest"), alpha = 0.3) +
geom_abline(intercept = 0, slope = 1, linetype = "dashed") +
scale_x_continuous(labels = dollar) + scale_y_continuous(labels = dollar) +
labs(
title = "Chart 2: Predicted vs. Actual Sale Price",
x = "Actual Sale Price (USD)",        # 明确 X 轴
y = "Predicted Sale Price (USD)",     # 修改这里：将 KNN_USD 改为通用标题
color = "Model"
) +
theme_minimal()
# Chart 3: Error Consistency - Visualizes which model is more stable across different price points.
ggplot(results, aes(x = Actual_USD)) +
geom_point(aes(y = KNN_Error_USD, color = "KNN (Comps)"), alpha = 0.4) +
geom_point(aes(y = RF_Error_USD, color = "Random Forest"), alpha = 0.4) +
geom_smooth(aes(y = KNN_Error_USD, color = "KNN (Comps)"), se = FALSE) +
geom_smooth(aes(y = RF_Error_USD, color = "Random Forest"), se = FALSE) +
scale_x_continuous(labels = dollar) + scale_y_continuous(labels = dollar) +
labs(
title = "Chart 3: Error Consistency Across Price Ranges",
x = "Actual Sale Price (USD)",        # 统一 X 轴格式
y = "Absolute Error (USD)",           # 修改这里：将 KNN_Error_USD 改为通用标题
color = "Model"
) +
theme_minimal()
# Chart 4: MAPE by Tier - A clear bar chart comparing error percentages across market segments.
tier_summary <- results %>%
group_by(Price_Tier) %>%
summarise(KNN = mean(KNN_APE)*100, RF = mean(RF_APE)*100) %>%
pivot_longer(cols = c(KNN, RF), names_to = "Model", values_to = "MAPE")
ggplot(tier_summary, aes(x = Price_Tier, y = MAPE, fill = Model)) +
geom_bar(stat = "identity", position = "dodge") +
geom_text(aes(label = round(MAPE, 1)), position = position_dodge(0.9), vjust = -0.5) +
labs(title = "Chart 4: Average Error % by Price", y = "MAPE (%)") +
theme_minimal()
