geom_line(color = "steelblue", size = 1) +      # 画折线
geom_point(color = "darkred", size = 3) +       # 画数据点
geom_vline(xintercept = 9, linetype = "dashed", color = "orange") + # 标注最优 K=9
annotate("text", x = 11, y = 0.19, label = "Optimal k = 9", color = "orange") + # 添加文字说明
labs(title = "Chart 1: KNN Hyperparameter Tuning",
subtitle = "Finding the optimal k via 10-fold Cross-Validation",
x = "Number of Neighbors (k)",
y = "RMSE (Error Rate)") +
theme_minimal()
