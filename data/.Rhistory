# Chart 6: Error Stability - Boxplots showing the reliability of each model (shorter boxes = more reliable).
boxplot_data <- results %>%
select(Price_Tier, KNN_APE, RF_APE) %>%
pivot_longer(cols = c(KNN_APE, RF_APE), names_to = "Model", values_to = "APE") %>%
mutate(APE_Percent = APE * 100)
ggplot(boxplot_data, aes(x = Price_Tier, y = APE_Percent, fill = Model)) +
geom_boxplot(outlier.alpha = 0.4) +
coord_cartesian(ylim = c(0, 50)) +
scale_fill_manual(values = c("KNN_APE" = "#F8766D", "RF_APE" = "#00BFC4"),
labels = c("KNN (Comps)", "Random Forest")) +
labs(title = "Chart 6: Error Stability by Price Tier", x = "Market Segment", y = "APE (%)") +
theme_minimal()
